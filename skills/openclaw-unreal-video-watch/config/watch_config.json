{
  "queries": [
    "https://www.youtube.com/@UnrealEngine/videos",
    "https://www.youtube.com/@UnrealEngine/streams"
  ],
  "max_age_hours": 48,
  "playlist_end": 40,
  "min_duration_seconds": 180,
  "top_n": 8,
  "metadata_enrich_limit": 20,
  "yt_dlp_timeout_seconds": 45,
  "no_check_certificates": true,
  "require_publish_date": true,
  "cookies_file": [
    "%LOCALAPPDATA%/OpenClawUnrealVideoWatch/cookies.txt",
    "secrets/cookies.txt"
  ],
  "cookies_from_browser": [
    "chrome",
    "edge"
  ],
  "exclude_keywords": [
    "shorts",
    "#shorts",
    "ad ",
    "advert",
    "sponsor",
    "sponsored",
    "car",
    "cars",
    "automotive",
    "vehicle",
